# ============================================================
# .gitignore for EACR-Professor Project
# ============================================================

# Dependency directories
node_modules/
vendor/

# Build outputs
dist/
build/
out/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.lnk

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Local development files
*.local
*.bak
*.tmp

# Secret files
*secret*
*.key
*.pem

# Firebase debug files
.firebase/

# Backup files
*.backup
*.old
